DATABASE_URL=postgresql://tenka:tenka@localhost:5432/tenka?schema=public

# Seed da primeira empresa e do primeiro admin
SEED_ORG_SLUG=tenka
SEED_ORG_NOME=Tenka
SEED_ADMIN_LOGIN=admin
SEED_ADMIN_SENHA=

# Fase 2 — sem estes, o app sobe e as rotas de WhatsApp devolvem 503
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=dev-evolution-key
WHATSAPP_WEBHOOK_SECRET=
# URL que a Evolution usa para ENTREGAR o webhook. Com a Evolution em Docker e o
# app no host (npm run dev), "localhost" aponta para o próprio container e o
# webhook nunca chega. No Docker Desktop (Windows/Mac) use host.docker.internal:
PUBLIC_APP_URL=http://host.docker.internal:3000
