# Banco DEDICADO aos testes. A suíte apaga todas as tabelas entre os casos
# (src/lib/test/db.ts), então NUNCA pode apontar para o banco de dev/produção.
# `limparBanco` recusa rodar se o nome do banco não contiver "test".
# Setup: docker exec tenkacall-db-1 psql -U tenka -d tenka -c "CREATE DATABASE tenka_test;"
#        DATABASE_URL=...tenka_test... npx prisma migrate deploy
DATABASE_URL=postgresql://tenka:tenka@localhost:5432/tenka_test?schema=public
